# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
ENVIRONMENT=development

# Pi Routing - add your Raspberry Pi endpoints
PI_NODE_1=http://192.168.1.100:8080
PI_NODE_2=http://192.168.1.101:8080
PI_NODE_3=http://192.168.1.102:8080
PI_HEALTH_CHECK_INTERVAL=30

# Database (SQLite for local, Postgres URI for production)
DATABASE_URL=sqlite:///./blackroad.db
